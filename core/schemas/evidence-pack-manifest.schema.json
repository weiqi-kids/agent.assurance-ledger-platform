{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/schemas/evidence-pack-manifest.schema.json",
  "title": "Evidence Pack Manifest",
  "description": "Manifest for deterministic evidence pack ZIP files. Records all artifacts, their hashes, and the overall pack hash for tamper detection.",
  "type": "object",
  "required": [
    "schema_version",
    "period",
    "generated_at",
    "generated_by",
    "artifact_list",
    "artifact_hashes",
    "pack_hash",
    "signed_by",
    "approval_timestamp"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for this document"
    },
    "period": {
      "type": "string",
      "pattern": "^\\d{4}-(Q[1-4]|H[12]|\\d{2})$",
      "description": "Audit period identifier (e.g., 2026-Q1, 2026-H1, 2026-03)"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the evidence pack was generated"
    },
    "generated_by": {
      "type": "string",
      "minLength": 1,
      "description": "System or user that generated the evidence pack"
    },
    "artifact_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Artifact"
      },
      "description": "Ordered list of artifacts included in the pack (lexicographic sort)"
    },
    "artifact_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      },
      "description": "Map of artifact path to its SHA-256 hash"
    },
    "pack_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of the entire evidence pack ZIP"
    },
    "signed_by": {
      "type": "string",
      "minLength": 1,
      "description": "Identity (GPG key ID or user) that signed the pack"
    },
    "approval_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the pack was approved"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Artifact": {
      "type": "object",
      "required": ["path", "type", "control_id", "size_bytes"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path of the artifact within the pack"
        },
        "type": {
          "type": "string",
          "description": "MIME type or evidence category"
        },
        "control_id": {
          "type": "string",
          "pattern": "^(AC|CM|PI|CF|IR|MN)-\\d{3}$",
          "description": "Control this artifact provides evidence for"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "File size in bytes"
        }
      },
      "additionalProperties": false
    }
  }
}
