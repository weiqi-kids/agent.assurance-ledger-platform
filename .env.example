# ===========================================
# Database
# ===========================================
DB_DRIVER=sqlite
# SQLite: file:./dev.db
# PostgreSQL: postgresql://user:password@localhost:5432/assurance_ledger
DATABASE_URL=file:./dev.db

# ===========================================
# NextAuth.js
# ===========================================
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-domain.com

# ===========================================
# Google OAuth
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# LINE OAuth
# Requires LINE Login channel in LINE Developers Console
# Callback URL: ${NEXTAUTH_URL}/api/auth/callback/line
# Scopes: profile openid (email requires separate application)
# ===========================================
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# ===========================================
# GitHub App
# Create at: https://github.com/settings/apps
# Required permissions: Issues (read/write), Contents (read/write)
# ===========================================
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_INSTALLATION_ID=
# Format: owner/repo (used by app-auth.ts getRepoInfo())
GITHUB_REPOSITORY=weiqi-kids/agent.assurance-ledger-platform

# ===========================================
# AI Provider API Keys
# Only add keys for providers you want to enable.
# Provider instances are configured in the Web UI Settings.
# ===========================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
